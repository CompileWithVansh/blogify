# =============================================
# BLOGIFY BACKEND - ENVIRONMENT VARIABLES
# =============================================
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=1337

# -----------------------------------------------
# STRAPI SECRETS
# How to generate: run `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
# in your terminal for each one
# -----------------------------------------------
APP_KEYS="key1,key2,key3,key4"
API_TOKEN_SALT=your_api_token_salt_here
ADMIN_JWT_SECRET=your_admin_jwt_secret_here
TRANSFER_TOKEN_SALT=your_transfer_token_salt_here
JWT_SECRET=your_jwt_secret_here

# -----------------------------------------------
# DATABASE (PostgreSQL - for production on Render)
# How to get: Create a free PostgreSQL DB on https://render.com
# → New → PostgreSQL → copy the "External Database URL"
# -----------------------------------------------
DATABASE_CLIENT=sqlite
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_SSL=true

# -----------------------------------------------
# CLOUDINARY (for blog image uploads)
# How to get:
#   1. Go to https://cloudinary.com and sign up (free)
#   2. Dashboard → copy Cloud Name, API Key, API Secret
# -----------------------------------------------
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
