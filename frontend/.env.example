# =============================================
# BLOGIFY FRONTEND - ENVIRONMENT VARIABLES
# =============================================
# Copy this file to .env.local and fill in your values

# -----------------------------------------------
# STRAPI BACKEND URL
# Local: http://localhost:1337
# Production: your Render backend URL
# -----------------------------------------------
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# -----------------------------------------------
# STRAPI API TOKEN
# How to generate:
#   1. Start your Strapi backend (npm run dev)
#   2. Go to http://localhost:1337/admin
#   3. Settings → API Tokens → Create new token
#   4. Name: "blogify-frontend", Type: "Full access"
#   5. Copy the token here
# -----------------------------------------------
STRAPI_API_TOKEN=your_strapi_api_token_here

# -----------------------------------------------
# CLERK AUTHENTICATION
# How to get:
#   1. Go to https://clerk.com and sign up (free)
#   2. Create a new application → name it "Blogify"
#   3. Dashboard → API Keys
#   4. Copy "Publishable key" → NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
#   5. Copy "Secret key" → CLERK_SECRET_KEY
# -----------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Clerk redirect URLs (keep these as-is for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# -----------------------------------------------
# UNSPLASH (for cover image search - optional)
# How to get:
#   1. Go to https://unsplash.com/developers
#   2. Register as a developer → New Application
#   3. Copy "Access Key"
# -----------------------------------------------
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# App URL (used for SEO metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
